-#include < string.h>
- //定义图书信息结构体
- typedef struct
- {
-     查尔·布诺[20];         //书号
-     角色标题[50];        //书名
-     查尔·斯诺[20];          //借阅人学号
-     智力bStatus;           //借阅状态，0表示未借出，1表示借出
- } 书籍;
- //定义图书信息的结点结构
- typedef struct 节点
- {
-     书籍;
-     接下来是struct节点*;
- } ListNode， * LinkList;
- //初始化图书信息表
- LinkList 初始列表（InitList）
- {
-     链接列表 L;
-     L = （ListNode*）malloc（sizeof（ListNode））;//为头结点分配内存空间
